// Assume a connection to the database has been established as $conn
if (isset($_POST['submit']) && isset($_FILES['image'])) {
    $user_id = $_SESSION['user_id']; // Get the logged-in user's ID
    
    
    $image = $_FILES['image'];
    $imageName = $image['name'];
    $imageTmpName = $image['tmp_name'];
    $imageSize = $image['size'];
    $imageError = $image['error'];
    $imageType = $image['type'];

    $imageExt = strtolower(pathinfo($imageName, PATHINFO_EXTENSION));
    $allowedExt = ['jpg', 'jpeg', 'png'];

    // Check if the uploaded file is an allowed image type
    if (in_array($imageExt, $allowedExt)) {
        if ($imageError === 0) {
            if ($imageSize < 5000000) { // Limit image size to 5MB
                $imageNewName = "profile_".$user_id.".".$imageExt;
                $imageDestination = "uploads/".$imageNewName;
                
                // Move the uploaded file to the 'uploads' directory
                if (move_uploaded_file($imageTmpName, $imageDestination)) {
                    // Update the user's profile image path in the database
                    $query = "UPDATE users SET profile_image = ? WHERE id = ?";
                    $stmt = $conn->prepare($query);
                    $stmt->bind_param("si", $imageDestination, $user_id);
                    $stmt->execute();
                    
                    // Redirect or notify the user
                    header("Location: profile.php");
                    exit();
                } else {
                    echo "Error uploading the file.";
                }
            } else {
                echo "Your file is too large.";
            }
        } else {
            echo "There was an error uploading the image.";
        }
    } else {
        echo "Only JPG, JPEG, and PNG files are allowed.";
    }
}
