    <!-- JavaScript -->
    <script>
        document.getElementById("registrationForm").addEventListener("submit", function(event) {
            event.preventDefault(); // Prevent page reload

            let hasError = false;

            // Get input values
            const code = document.getElementById("code");
            const username = document.getElementById("username");
            const password = document.getElementById("password");
            const fullName = document.getElementById("full_name");
            const email = document.getElementById("email");

            // Error message containers
            const codeError = document.getElementById("code-error");
            const usernameError = document.getElementById("username-error");
            const passwordError = document.getElementById("password-error");
            const fullNameError = document.getElementById("full_name-error");
            const emailError = document.getElementById("email-error");

            // Reset error messages
            document.querySelectorAll(".error-message").forEach(e => e.classList.add("hidden"));

            // Check fields
            if (!code.value.trim()) {
                codeError.classList.remove("hidden");
                hasError = true;
            }

            if (!username.value.trim()) {
                usernameError.classList.remove("hidden");
                hasError = true;
            }

            if (!password.value.trim()) {
                passwordError.classList.remove("hidden");
                hasError = true;
            }

            if (!fullName.value.trim()) {
                fullNameError.classList.remove("hidden");
                hasError = true;
            }

            if (!email.value.trim() || !email.value.includes("@")) {
                emailError.classList.remove("hidden");
                hasError = true;
            }

            // Submit the form only if there are no errors
            if (!hasError) {
                alert("Registration successful!"); // Placeholder for success
            }
        });
    </script>
</body>
</html>
