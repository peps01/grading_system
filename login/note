if (isset($_POST['createAccBtn'])) {
    $conn = conn();

    $username = $_POST['username'];
    $password = $_POST['password'];
    $full_name = $_POST['full_name'];
    $email = $_POST['email'];
    $role_id = $_POST['role_id']; // Assume 'Student' role ID is passed
    $instructor_code = $_POST['instructor_code']; // Code provided during registration

    // Check if the user trying to create the account is an instructor
    $creator_id = $_SESSION['user_id']; // Assuming the logged-in instructor's ID is stored in session
    $creator_role_query = "SELECT role_id FROM users WHERE id = '$creator_id'";
    $creator_role_result = mysqli_query($conn, $creator_role_query);
    $creator_role = mysqli_fetch_assoc($creator_role_result)['role_id'];

    if ($creator_role != 1) { // Assuming '1' is the role ID for instructors
        echo "<script>
            alert('Only instructors can create student accounts.');
            window.location.href = '../login/createAccount.php';
        </script>";
        exit;
    }

    // Check if the provided instructor code is valid
    $code_query = "SELECT * FROM parent_codes WHERE code = '$instructor_code' AND student_id IS NULL";
    $code_result = mysqli_query($conn, $code_query);

    if (mysqli_num_rows($code_result) == 0) {
        echo "<script>
            alert('Invalid or already used instructor code.');
            window.location.href = '../login/createAccount.php';
        </script>";
        exit;
    }

    // Check if the username already exists
    $check_query = "SELECT * FROM users WHERE username = '$username'";
    $check_result = mysqli_query($conn, $check_query);

    if (mysqli_num_rows($check_result) > 0) {
        echo "<script>
            alert('Username already exists. Please choose a different username.');
            window.location.href = '../login/createAccount.php';
        </script>";
        exit;
    } else {
        // Hash the password before storing it in the database
        $hashed_password = password_hash($password, PASSWORD_DEFAULT);

        $query = "INSERT INTO users (username, password, full_name, email, role_id) 
                  VALUES ('$username', '$hashed_password', '$full_name', '$email', '$role_id')";

        if (mysqli_query($conn, $query)) {
            // Get the new user's ID
            $new_user_id = mysqli_insert_id($conn);

            // Update the parent_codes table to link the code to the newly created student
            $update_code_query = "UPDATE parent_codes SET student_id = '$new_user_id' WHERE code = '$instructor_code'";
            mysqli_query($conn, $update_code_query);

            header('Location: ../public/role.php');
        } else {
            echo "Error: " . $query . "<br>" . mysqli_error($conn);
        }
    }

    mysqli_close($conn);
}
